{
    "name": "ortic/laravel-duckdb-pdo",
    "description": "DuckDB database driver for Laravel, backed by the native pdo_duckdb extension.",
    "keywords": ["laravel", "duckdb", "database", "pdo"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "ext-pdo_duckdb": "*",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": { "Ortic\\DuckDB\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Ortic\\DuckDB\\Tests\\": "tests/" }
    },
    "extra": {
        "laravel": {
            "providers": ["Ortic\\DuckDB\\DuckDBServiceProvider"]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
